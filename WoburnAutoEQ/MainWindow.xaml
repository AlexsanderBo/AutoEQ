<Window x:Class="WoburnAutoEQ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoEQ" Height="790" Width="1160" MinHeight="710" MinWidth="1000"
        Background="#07090F" FontFamily="Segoe UI, Segoe UI Variable Text">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#090D14" />
        <SolidColorBrush x:Key="PanelBrush" Color="#101827" />
        <SolidColorBrush x:Key="CreamBrush" Color="#FFF1CF" />
        <SolidColorBrush x:Key="GoldBrush" Color="#F6B642" />
        <SolidColorBrush x:Key="CopperBrush" Color="#C76B1C" />
        <SolidColorBrush x:Key="MintBrush" Color="#19E6C1" />
        <LinearGradientBrush x:Key="StageBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#162239" Offset="0" />
            <GradientStop Color="#07090F" Offset="0.48" />
            <GradientStop Color="#180F08" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GoldChromeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFE3A3" Offset="0" />
            <GradientStop Color="#F6B642" Offset="0.42" />
            <GradientStop Color="#C76B1C" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1C2942" Offset="0" />
            <GradientStop Color="#101827" Offset="0.52" />
            <GradientStop Color="#071D24" Offset="1" />
        </LinearGradientBrush>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFB000" />
            <Setter Property="Foreground" Value="#101624" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome" Background="{TemplateBinding Background}" BorderBrush="#FFE3A3" BorderThickness="1" CornerRadius="18" Padding="{TemplateBinding Padding}" RenderTransformOrigin="0.5,0.5">
                            <Border.Effect>
                                <DropShadowEffect Color="#F6B642" BlurRadius="12" ShadowDepth="0" Opacity="0.22" />
                            </Border.Effect>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.72" />
                                <Setter TargetName="ButtonChrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F8F1E3" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PillCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F8F1E3" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Pill" Background="#1B2740" BorderBrush="#52627A" BorderThickness="1" CornerRadius="18" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="Dot" Width="12" Height="12" CornerRadius="6" Background="#8EA0B8" Margin="0,0,8,0" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="#FFB000" />
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#F8F1E3" />
                                <Setter TargetName="Dot" Property="Background" Value="#101624" />
                                <Setter Property="Foreground" Value="#101624" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#FFD166" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AmpSwitchCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFF3C4" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="SwitchPlate" Background="#111827" BorderBrush="#52627A" BorderThickness="1" CornerRadius="18" Padding="6">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="SwitchTrack" Width="32" Height="20" CornerRadius="10" Background="#293449" Margin="0,0,8,0">
                                    <Ellipse x:Name="SwitchKnob" Width="14" Height="14" Fill="#8EA0B8" HorizontalAlignment="Left" Margin="3,0,0,0" />
                                </Border>
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchPlate" Property="Background" Value="#0B3D34" />
                                <Setter TargetName="SwitchPlate" Property="BorderBrush" Value="#19E6C1" />
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#19E6C1" />
                                <Setter TargetName="SwitchKnob" Property="Fill" Value="#101624" />
                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchKnob" Property="Margin" Value="0,0,3,0" />
                                <Setter Property="Foreground" Value="#D7FFF5" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchPlate" Property="BorderBrush" Value="#FFD166" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#FFB000" />
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border Background="#1B2740" CornerRadius="5" />
                            <Border x:Name="PART_Track" Background="Transparent" CornerRadius="5" />
                            <Grid x:Name="PART_Indicator" HorizontalAlignment="Left" ClipToBounds="True">
                                <Border CornerRadius="5" Background="{TemplateBinding Foreground}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#19E6C1" BlurRadius="12" ShadowDepth="0" Opacity="0.28" />
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F8F1E3" />
            <Setter Property="Background" Value="#0B1020" />
            <Setter Property="BorderBrush" Value="#FFB000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="PresetChrome" CornerRadius="18" BorderBrush="#FFB000" BorderThickness="1" Padding="14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#101624" Offset="0" />
                                                    <GradientStop Color="#1B2740" Offset="0.55" />
                                                    <GradientStop Color="#073B4C" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="9" Height="9" Fill="#19E6C1" Margin="0,0,10,0" VerticalAlignment="Center" />
                                                <ContentPresenter Grid.Column="1" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" HorizontalAlignment="Left" VerticalAlignment="Center" RecognizesAccessKey="True" />
                                                <TextBlock Grid.Column="2" Text="⌄" Foreground="#FFD166" FontSize="18" FontWeight="Black" VerticalAlignment="Center" Margin="10,0,0,2" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PresetChrome" Property="BorderBrush" Value="#19E6C1" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="PresetChrome" Property="BorderBrush" Value="#F8F1E3" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" Margin="34,0,38,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#0B1020" BorderBrush="#FFB000" BorderThickness="1" CornerRadius="16" Padding="6" Margin="0,6,0,0" MinWidth="260">
                                    <ScrollViewer MaxHeight="260">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F8F1E3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#20304F" />
                                <Setter Property="Foreground" Value="#FFD166" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#073B4C" />
                                <Setter Property="Foreground" Value="#D7FFF5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.Background>
            <StaticResource ResourceKey="StageBrush" />
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Ellipse Grid.RowSpan="3" Width="520" Height="520" Fill="#20304F" Opacity="0.38" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-190,-250,0,0" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="80" />
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Grid.RowSpan="3" Width="420" Height="420" Fill="#C76B1C" Opacity="0.22" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-210,-120,0" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="78" />
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Grid.RowSpan="3" Width="360" Height="360" Fill="#073B4C" Opacity="0.32" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-160,-130" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="70" />
            </Ellipse.Effect>
        </Ellipse>

        <Border Padding="26" CornerRadius="30" BorderBrush="#FFE3A3" BorderThickness="1.4">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFF6DB" Offset="0" />
                    <GradientStop Color="#F8D48A" Offset="0.52" />
                    <GradientStop Color="#D18A30" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="34" ShadowDepth="12" Opacity="0.36" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="AutoEQ" FontSize="44" FontWeight="Black" Foreground="#090D14" />
                    <TextBlock Text="Tự động tinh chỉnh âm thanh- phân tích WASAPI." Foreground="#4E3924" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <WrapPanel Margin="0,14,24,0">
                        <Border Background="#090D14" BorderBrush="#19E6C1" BorderThickness="1" CornerRadius="16" Padding="12,7" Margin="0,0,8,8" MaxWidth="510">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#19E6C1" Margin="0,0,9,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="DeviceLabel" Text="Mainboard: đang đọc..." Foreground="#D7FFF5" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Background="#090D14" BorderBrush="#FFB000" BorderThickness="1" CornerRadius="16" Padding="12,7" Margin="0,0,8,8" MaxWidth="510">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#FFB000" Margin="0,0,9,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="SoundCardLabel" Text="Soundcard: đang đọc..." Foreground="#FFF3C4" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                    <Border Background="#101624" BorderBrush="#FFB000" BorderThickness="1" CornerRadius="16" Padding="12,7" Margin="0,0,24,0" HorizontalAlignment="Left">
                        <TextBlock x:Name="ShortcutLabel" Text="Phím tắt: Ctrl+E Auto EQ | Ctrl+R đồng bộ sound output | Ctrl+Enter áp preset" Foreground="#FFF3C4" FontSize="11" FontWeight="Bold" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#090D14" CornerRadius="18" Padding="12,9" Margin="0,0,10,0">
                        <TextBlock Text="DSP CỤC BỘ" Foreground="#F6B642" FontSize="11" FontWeight="Black" />
                    </Border>
                <Border Background="#101624" BorderBrush="#19E6C1" BorderThickness="1" CornerRadius="22" Padding="18,12" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="#19E6C1" Margin="0,0,10,0" />
                        <TextBlock x:Name="MonitoringStatusLabel" Text="SẴN SÀNG" Foreground="#F8F1E3" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*" />
                <ColumnDefinition Width="1.38*" />
                <ColumnDefinition Width="0.98*" />
            </Grid.ColumnDefinitions>

            <Border Padding="0" CornerRadius="30" BorderBrush="#F6B642" BorderThickness="1.5" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFE3A3" Offset="0" />
                        <GradientStop Color="#C76B1C" Offset="0.58" />
                        <GradientStop Color="#101624" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="10" Opacity="0.42" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Padding="18,15" CornerRadius="28,28,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#090D14" Offset="0" />
                                <GradientStop Color="#142032" Offset="0.58" />
                                <GradientStop Color="#071D24" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    <Grid>
                        <TextBlock Text="BẢNG ĐIỀU KHIỂN" Foreground="#FFF3C4" FontWeight="Black" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    </Border>

                <StackPanel Grid.Row="1" Margin="16">
                    <Border x:Name="AutoEqStatusCard" CornerRadius="22" Padding="14" BorderBrush="#19E6C1" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush x:Name="AutoEqStatusBrush" StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#123B35" Offset="0" />
                                <GradientStop Color="#0B1020" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect x:Name="AutoEqStatusGlow" Color="#19E6C1" BlurRadius="20" ShadowDepth="0" Opacity="0.24" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <DockPanel LastChildFill="True">
                                    <Ellipse x:Name="AutoEqStatusDot" Width="9" Height="9" Fill="#19E6C1" Margin="0,0,7,0" VerticalAlignment="Center" />
                                    <TextBlock Text="AUTO EQ" Foreground="#D7FFF5" FontSize="11" FontWeight="Black" />
                                </DockPanel>
                                <TextBlock x:Name="AutoEqStatusLabel" Text="Đang bật - tự nghe và chọn preset APO" Foreground="#D7FFF5" FontSize="11" FontWeight="Bold" Margin="0,3,0,0" />
                                <TextBlock x:Name="AutoEqStatusHintLabel" Text="Bật Auto EQ là hệ thống tự phân tích âm thanh ngay." Foreground="#8EA0B8" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="AutoEqCheckBox" Grid.Column="1" Style="{StaticResource AmpSwitchCheckBox}" Content="BẬT" IsChecked="True" VerticalAlignment="Center" Checked="AutoEqCheckBox_StateChanged" Unchecked="AutoEqCheckBox_StateChanged" />
                        </Grid>
                    </Border>

                    <Border x:Name="ManualPresetPanel" CornerRadius="22" BorderBrush="#F6B642" BorderThickness="1" Padding="14" Margin="0,12,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#101827" Offset="0" />
                                <GradientStop Color="#172033" Offset="0.58" />
                                <GradientStop Color="#073B4C" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="PRESET ĐA THIẾT BỊ" Foreground="#FFB000" FontSize="10" FontWeight="Black" />
                                    <TextBlock Text="Chọn màu âm cho loa, tai nghe, Bluetooth hoặc sound card" Foreground="#D7FFF5" FontSize="11" FontWeight="SemiBold" Margin="0,3,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Background="#FFB000" CornerRadius="12" Padding="8,4" VerticalAlignment="Top">
                                    <TextBlock Text="APO" Foreground="#101624" FontSize="10" FontWeight="Black" />
                                </Border>
                            </DockPanel>
                            <ComboBox x:Name="PresetComboBox" Grid.Row="1" Height="44" SelectionChanged="PresetComboBox_SelectionChanged" Margin="0,11,0,0" />
                            <TextBlock Grid.Row="2" Text="Preset thủ công dành cho nhiều thiết bị; Auto EQ sẽ tự chọn theo âm thanh và output đang dùng." Foreground="#8EA0B8" FontSize="10" TextWrapping="Wrap" Margin="0,8,0,0" />
                        </Grid>
                    </Border>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                    <Grid Width="140" Height="140" HorizontalAlignment="Left">
                        <Ellipse Stroke="#FFE3A3" StrokeThickness="2">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#1B2740" Offset="0" />
                                    <GradientStop Color="#070B12" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Path Stroke="#52627A" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 33 102 A 46 46 0 1 1 99 102" />
                        <Path Stroke="#FFB000" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 33 102 A 46 46 0 0 1 45 34" />
                        <Ellipse Width="92" Height="92" Stroke="#F6B642" StrokeThickness="2">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#1B2740" Offset="0" />
                                    <GradientStop Color="#101827" Offset="0.7" />
                                    <GradientStop Color="#070B12" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="66" Height="66" Stroke="#52627A" StrokeThickness="1" Opacity="0.9" />
                        <Line x:Name="VolumeNeedle" X1="70" Y1="70" X2="70" Y2="30" Stroke="#FFF3C4" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Line.Effect>
                                <DropShadowEffect Color="#F6B642" BlurRadius="10" ShadowDepth="0" Opacity="0.55" />
                            </Line.Effect>
                            <Line.RenderTransform>
                                <RotateTransform x:Name="VolumeNeedleTransform" CenterX="70" CenterY="70" Angle="0" />
                            </Line.RenderTransform>
                        </Line>
                        <Ellipse Width="22" Height="22" Fill="#FFB000" Stroke="#F8F1E3" StrokeThickness="2" />
                        <TextBlock Text="ÂM LƯỢNG" Foreground="#FFF3C4" FontSize="10" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16" />
                        <Border Background="Transparent" Cursor="Hand" MouseLeftButtonDown="VolumeKnob_MouseLeftButtonDown" MouseMove="VolumeKnob_MouseMove" MouseLeftButtonUp="VolumeKnob_MouseLeftButtonUp" MouseWheel="VolumeKnob_MouseWheel" />
                    </Grid>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="CHẾ ĐỘ PHÒNG" Foreground="#F8F1E3" FontSize="10" FontWeight="Black" Margin="0,0,0,8" />
                        <CheckBox x:Name="NearWallCheckBox" Style="{StaticResource AmpSwitchCheckBox}" Content="Gần tường" Margin="0,0,0,9" />
                        <CheckBox x:Name="NightModeCheckBox" Style="{StaticResource AmpSwitchCheckBox}" Content="Nghe đêm" />
                    </StackPanel>
                    </Grid>
                </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="18" CornerRadius="30" Background="#F8F1E3" Margin="18,-8,0,-6">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.28" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

