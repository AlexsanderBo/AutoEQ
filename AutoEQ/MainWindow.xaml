                                <Grid Margin="0,0,0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="26" Height="26" CornerRadius="13" Background="#D6B25E" Margin="0,0,7,0">
                                        <TextBlock Text="V" Foreground="#17140F" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="VOCAL" Foreground="#D6B25E" FontSize="12" FontWeight="Black" />
                                        <TextBlock Text="GIỌNG / MID" Foreground="#E9D8A6" FontSize="8.5" FontWeight="Black" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="VocalHintLabel" Text="Độ rõ giọng / thân âm trung" Foreground="#F2E6C8" FontSize="12" FontWeight="Black" TextWrapping="Wrap" LineHeight="15" />
                                <Border Background="#241C12" CornerRadius="10" Padding="7,3" Margin="0,8,0,0" HorizontalAlignment="Left">
                                    <TextBlock Text="500 Hz–3 kHz" Foreground="#E9D8A6" FontSize="9" FontWeight="Black" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border x:Name="TrebleBandCard" Grid.Column="4" CornerRadius="18" BorderBrush="#E5C778" BorderThickness="1.6" Padding="11" MinHeight="92">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#5E3716" Offset="0" />
                                    <GradientStop Color="#10131B" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#E5C778" BlurRadius="12" ShadowDepth="0" Opacity="0.18" />
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="26" Height="26" CornerRadius="13" Background="#E5C778" Margin="0,0,7,0">
                                        <TextBlock Text="T" Foreground="#15120D" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="TREBLE" Foreground="#E5C778" FontSize="12" FontWeight="Black" />
                                        <TextBlock Text="CHI TIẾT CAO" Foreground="#F0DFA7" FontSize="8.5" FontWeight="Black" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="TrebleHintLabel" Text="Độ sáng / chi tiết không khí" Foreground="#F2E6C8" FontSize="12" FontWeight="Black" TextWrapping="Wrap" LineHeight="15" />
                                <Border Background="#3A2412" CornerRadius="10" Padding="7,3" Margin="0,8,0,0" HorizontalAlignment="Left">
                                    <TextBlock Text="4–16 kHz" Foreground="#F0DFA7" FontSize="9" FontWeight="Black" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                     <WrapPanel Margin="0,12,0,0" Visibility="Collapsed">
                        <Border Background="#3B3020" CornerRadius="14" Padding="9,5" Margin="0,0,6,6">
