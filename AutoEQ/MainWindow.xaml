                                            <TextBlock Text="{Binding TimeText}" Foreground="#D6B25E" FontSize="11" FontWeight="Black" />
                                            <TextBlock Text="{Binding LevelText}" Foreground="#A99A72" FontSize="10" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding DisplayMessage}" Foreground="#F2E6C8" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>




































