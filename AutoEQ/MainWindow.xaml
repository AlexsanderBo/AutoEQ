                                </Border>
                            </UniformGrid>
                            <TextBlock x:Name="SoundLinkDetailLabel" Text="Người dùng nhìn từ trái sang phải: tín hiệu vào, app phân tích dải nổi bật, rồi EQ phản hồi theo dữ liệu đó." Foreground="#6F603D" FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,10,0,0" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="BassBandCard" CornerRadius="18" BorderBrush="#D6B25E" BorderThickness="1.6" Padding="11" MinHeight="92">

                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#17140F" Offset="0" />
                                    <GradientStop Color="#0E0C09" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#D6B25E" BlurRadius="12" ShadowDepth="0" Opacity="0.18" />
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="26" Height="26" CornerRadius="13" Background="#D6B25E" Margin="0,0,7,0">
                                        <TextBlock Text="B" Foreground="#15120D" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="BASS" Foreground="#D6B25E" FontSize="12" FontWeight="Black" />
                                        <TextBlock Text="DẢI TRẦM" Foreground="#B7A77D" FontSize="8.5" FontWeight="Black" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="BassHintLabel" Text="Lực trầm / độ dày nền âm" Foreground="#F2E6C8" FontSize="12" FontWeight="Black" TextWrapping="Wrap" LineHeight="15" />
                                <Border Background="#332A16" CornerRadius="10" Padding="7,3" Margin="0,8,0,0" HorizontalAlignment="Left">
                                    <TextBlock Text="60–250 Hz" Foreground="#E5C778" FontSize="9" FontWeight="Black" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border x:Name="VocalBandCard" Grid.Column="2" CornerRadius="18" BorderBrush="#D6B25E" BorderThickness="1.6" Padding="11" MinHeight="92">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2A2217" Offset="0" />
                                    <GradientStop Color="#0B0B0D" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#D6B25E" BlurRadius="12" ShadowDepth="0" Opacity="0.2" />
                            </Border.Effect>
