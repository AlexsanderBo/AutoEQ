                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="18" Background="#120F0A" BorderBrush="#D6B25E" BorderThickness="1" Padding="10">
                            <StackPanel HorizontalAlignment="Center">
                                <Grid Width="62" Height="62">
                                    <Ellipse Stroke="#3B3020" StrokeThickness="7" />
                                    <Path x:Name="BassRadialArc" Stroke="#D6B25E" StrokeThickness="7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 31 6 A 25 25 0 1 1 30.9 6" Opacity="0.9" />
                                    <TextBlock x:Name="BassPercentLabel" Text="42" Foreground="#D6B25E" FontSize="18" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Text="BASS" Foreground="#D6B25E" FontSize="10" FontWeight="Black" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" CornerRadius="18" Background="#120F0A" BorderBrush="#D6B25E" BorderThickness="1" Padding="10">
                            <StackPanel HorizontalAlignment="Center">
                                <Grid Width="62" Height="62">
                                    <Ellipse Stroke="#3B3020" StrokeThickness="7" />
