<Window x:Class="AutoEQ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoEQ • Hi-Fi Control" Height="920" Width="1440" MinHeight="760" MinWidth="1120"
        Background="#050505" FontFamily="Segoe UI, Segoe UI Variable Text">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#050505" />
        <SolidColorBrush x:Key="PanelBrush" Color="#15120D" />
        <SolidColorBrush x:Key="CreamBrush" Color="#E9D8A6" />
        <SolidColorBrush x:Key="GoldBrush" Color="#D6B25E" />
        <SolidColorBrush x:Key="CopperBrush" Color="#8C5A22" />
        <SolidColorBrush x:Key="MintBrush" Color="#D6B25E" />
        <SolidColorBrush x:Key="StageBrush" Color="#050505" />

        <LinearGradientBrush x:Key="GoldChromeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E5C778" Offset="0" />
            <GradientStop Color="#D6B25E" Offset="0.42" />
            <GradientStop Color="#8C5A22" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#181512" Offset="0" />
            <GradientStop Color="#15120D" Offset="0.52" />
            <GradientStop Color="#0A0907" Offset="1" />
        </LinearGradientBrush>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#D6B25E" />
            <Setter Property="Foreground" Value="#17140F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome" Background="{TemplateBinding Background}" BorderBrush="#E5C778" BorderThickness="1" CornerRadius="18" Padding="{TemplateBinding Padding}" RenderTransformOrigin="0.5,0.5">
                            <Border.Effect>
                                <DropShadowEffect Color="#D6B25E" BlurRadius="10" ShadowDepth="0" Opacity="0.14" />
                            </Border.Effect>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.72" />
                                <Setter TargetName="ButtonChrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F2E6C8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PillCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F2E6C8" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Pill" Background="#272016" BorderBrush="#6F603D" BorderThickness="1" CornerRadius="18" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="Dot" Width="12" Height="12" CornerRadius="6" Background="#A99A72" Margin="0,0,8,0" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                 <Setter TargetName="Pill" Property="Background" Value="#D6B25E" />
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#F2E6C8" />
                                <Setter TargetName="Dot" Property="Background" Value="#17140F" />
                                <Setter Property="Foreground" Value="#17140F" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#D6B25E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AmpSwitchCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F0DFA7" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="SwitchPlate" Background="#15120D" BorderBrush="#6F603D" BorderThickness="1" CornerRadius="20" Padding="7" RenderTransformOrigin="0.5,0.5">
                            <Border.Effect>
                                <DropShadowEffect Color="#D6B25E" BlurRadius="0" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="SwitchTrack" Width="38" Height="22" CornerRadius="11" Background="#3A3020" Margin="0,0,8,0">
                                    <Ellipse x:Name="SwitchKnob" Width="16" Height="16" Fill="#A99A72" HorizontalAlignment="Left" Margin="3,0,0,0" />
                                </Border>
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchPlate" Property="Background" Value="#2A2217" />
                                <Setter TargetName="SwitchPlate" Property="BorderBrush" Value="#D6B25E" />
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#D6B25E" />
                                <Setter TargetName="SwitchKnob" Property="Fill" Value="#17140F" />
                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchKnob" Property="Margin" Value="0,0,3,0" />
                                <Setter TargetName="SwitchPlate" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#D6B25E" BlurRadius="18" ShadowDepth="0" Opacity="0.42" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#E9D8A6" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchPlate" Property="BorderBrush" Value="#D6B25E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SwitchPlate" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#D6B25E" />
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border Background="#272016" CornerRadius="5" />
                            <Border x:Name="PART_Track" Background="Transparent" CornerRadius="5" />
                            <Grid x:Name="PART_Indicator" HorizontalAlignment="Left" ClipToBounds="True">
                                <Border CornerRadius="5" Background="{TemplateBinding Foreground}">
                                    <Border.Effect>
                <DropShadowEffect Color="#D6B25E" BlurRadius="10" ShadowDepth="0" Opacity="0.18" />
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F2E6C8" />
            <Setter Property="Background" Value="#0B0B0D" />
            <Setter Property="BorderBrush" Value="#D6B25E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="PresetChrome" CornerRadius="18" BorderBrush="#D6B25E" BorderThickness="1" Padding="14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#17140F" Offset="0" />
                                                    <GradientStop Color="#272016" Offset="0.55" />
                                                    <GradientStop Color="#241C12" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="9" Height="9" Fill="#D6B25E" Margin="0,0,10,0" VerticalAlignment="Center" />
                                                <ContentPresenter Grid.Column="1" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" HorizontalAlignment="Left" VerticalAlignment="Center" RecognizesAccessKey="True" />
                                                <TextBlock Grid.Column="2" Text="⌄" Foreground="#D6B25E" FontSize="18" FontWeight="Black" VerticalAlignment="Center" Margin="10,0,0,2" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PresetChrome" Property="BorderBrush" Value="#E5C778" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="PresetChrome" Property="BorderBrush" Value="#F2E6C8" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" Margin="34,0,38,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#0B0B0D" BorderBrush="#D6B25E" BorderThickness="1" CornerRadius="16" Padding="6" Margin="0,6,0,0" MinWidth="260">
                                    <ScrollViewer MaxHeight="260">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F2E6C8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#3B3020" />
                                <Setter Property="Foreground" Value="#D6B25E" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#241C12" />
                                <Setter Property="Foreground" Value="#E9D8A6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.08" GradientOrigin="0.5,0.05" RadiusX="0.95" RadiusY="0.85">
                <GradientStop Color="#241C12" Offset="0" />
                <GradientStop Color="#090807" Offset="0.42" />
                <GradientStop Color="#050505" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>
        <Border Padding="20" CornerRadius="22" BorderBrush="#3A3020" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#181512" Offset="0" />
                    <GradientStop Color="#11100D" Offset="0.55" />
                    <GradientStop Color="#0A0907" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="8" Opacity="0.22" />
            </Border.Effect>
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="AutoEQ" FontSize="40" FontWeight="Black" Foreground="#F2E6C8" />
                    <TextBlock Text="Premium Hi-Fi Auto Equalizer • Local WASAPI DSP" Foreground="#B7A77D" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" />

                    <WrapPanel Margin="0,14,24,0">
                        <Border Background="#050505" BorderBrush="#D6B25E" BorderThickness="1" CornerRadius="16" Padding="12,7" Margin="0,0,8,8" MaxWidth="510">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#D6B25E" Margin="0,0,9,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="DeviceLabel" Text="Mainboard: đang đọc..." Foreground="#E9D8A6" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Background="#050505" BorderBrush="#D6B25E" BorderThickness="1" CornerRadius="16" Padding="12,7" Margin="0,0,8,8" MaxWidth="510">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#D6B25E" Margin="0,0,9,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="SoundCardLabel" Text="Soundcard: đang đọc..." Foreground="#F0DFA7" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                    <Border Background="#17140F" BorderBrush="#D6B25E" BorderThickness="1" CornerRadius="16" Padding="12,7" Margin="0,0,24,0" HorizontalAlignment="Left">
                        <TextBlock x:Name="ShortcutLabel" Text="Phím tắt: Ctrl+E Auto EQ | Ctrl+R đồng bộ sound output | Ctrl+Enter áp preset" Foreground="#F0DFA7" FontSize="11" FontWeight="Bold" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#050505" CornerRadius="18" Padding="12,9" Margin="0,0,10,0">
                        <TextBlock Text="LOCAL HI-FI DSP" Foreground="#D6B25E" FontSize="11" FontWeight="Black" />
                    </Border>
                <Border Background="#17140F" BorderBrush="#D6B25E" BorderThickness="1" CornerRadius="22" Padding="18,12" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="#D6B25E" Margin="0,0,10,0" />
                        <TextBlock x:Name="MonitoringStatusLabel" Text="SẴN SÀNG" Foreground="#F2E6C8" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.82*" />
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Padding="0" CornerRadius="28" Background="#0D0C0A" BorderBrush="#342A1A" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Padding="18,14" CornerRadius="28,28,0,0" Background="#100E0A" BorderBrush="#403521" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="GENERAL CONTROL" Foreground="#F2E6C8" FontWeight="Black" FontSize="18" />
                        </StackPanel>
                    </Grid>
                    </Border>


                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16">
                    <Border x:Name="AutoEqStatusCard" CornerRadius="22" Padding="14" Margin="0,0,0,0" BorderBrush="#D6B25E" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush x:Name="AutoEqStatusBrush" StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2A2217" Offset="0" />
                                <GradientStop Color="#0B0B0D" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect x:Name="AutoEqStatusGlow" Color="#D6B25E" BlurRadius="20" ShadowDepth="0" Opacity="0.24" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <DockPanel LastChildFill="True">
                                    <Ellipse x:Name="AutoEqStatusDot" Width="9" Height="9" Fill="#D6B25E" Margin="0,0,7,0" VerticalAlignment="Center" />
                                    <TextBlock Text="AUTO EQ" Foreground="#E9D8A6" FontSize="11" FontWeight="Black" />
                                </DockPanel>
                                <TextBlock x:Name="AutoEqStatusLabel" Text="Đang bật • tự chọn preset APO" Foreground="#E9D8A6" FontSize="11" FontWeight="Bold" Margin="0,3,0,0" />
                                <TextBlock x:Name="AutoEqStatusHintLabel" Text="Ctrl+E Auto EQ • Ctrl+R đồng bộ output • Ctrl+Enter áp preset" Foreground="#A99A72" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="AutoEqCheckBox" Grid.Column="1" Style="{StaticResource AmpSwitchCheckBox}" Content="BẬT" IsChecked="True" VerticalAlignment="Center" Checked="AutoEqCheckBox_StateChanged" Unchecked="AutoEqCheckBox_StateChanged" />
                        </Grid>
                    </Border>

                    <Border x:Name="SoundPanel" CornerRadius="16" Padding="14" Margin="0,12,0,0" Background="#0B0B0D" BorderBrush="#332A1C" BorderThickness="1">
                        <StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                            <TextBlock Text="OUTPUT" Foreground="#E9D8A6" FontSize="13" FontWeight="Black" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#D6B25E" CornerRadius="14" Padding="10,5" VerticalAlignment="Center">
                                    <TextBlock Text="LIVE" Foreground="#17140F" FontSize="10" FontWeight="Black" />
                                </Border>
                            </Grid>
                            <Border CornerRadius="18" Background="#17140F" BorderBrush="#E5C778" BorderThickness="1" Padding="12,9" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" CornerRadius="19" Background="#D6B25E" Margin="0,0,10,0">
                                        <TextBlock Text="◉" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="WINDOWS OUTPUT" Foreground="#E5C778" FontSize="10" FontWeight="Black" />
                                        <TextBlock x:Name="CurrentSoundOutputLabel" Text="Đang đọc output..." Foreground="#F2E6C8" FontSize="13" FontWeight="Black" TextWrapping="Wrap" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border CornerRadius="16" Background="#120F0A" BorderBrush="#D6B25E" BorderThickness="1" Padding="12,9">
                                <Grid>
                                     <TextBlock Text="Điều khiển output và preset tại đây. Sóng âm / phân tích live nằm ở HI-FI METER bên phải." Foreground="#E9D8A6" FontSize="10.5" FontWeight="Bold" TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                            <Grid Margin="0,8,0,0" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="INPUT" Foreground="#A99A72" FontSize="9" FontWeight="Black" VerticalAlignment="Center" />
                                <Border Grid.Column="1" Height="6" CornerRadius="3" Background="#0B0B0D" BorderBrush="#3B3020" BorderThickness="1" Margin="8,0" ClipToBounds="True">
                                    <Border x:Name="SignalToEqFlowBar" Width="24" HorizontalAlignment="Left" CornerRadius="3" Background="#D6B25E" Opacity="0.45">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#D6B25E" BlurRadius="10" ShadowDepth="0" Opacity="0.42" />
                                        </Border.Effect>
                                    </Border>
                                </Border>
                                <TextBlock Text="EQ" Grid.Column="2" Foreground="#D6B25E" FontSize="9" FontWeight="Black" VerticalAlignment="Center" />
                            </Grid>
                             <TextBlock x:Name="SignalEqLinkLabel" Visibility="Collapsed" Text="Tín hiệu đầu vào: dùng để Auto EQ chọn preset/output. Biểu đồ phân tích chi tiết nằm ở HI-FI METER bên phải." Foreground="#E9D8A6" FontSize="10.5" FontWeight="Bold" TextWrapping="Wrap" Margin="0,7,0,0" />
                        </StackPanel>

                    </Border>

                    <Border x:Name="ManualPresetPanel" CornerRadius="24" Padding="14" Margin="0,12,0,0" BorderBrush="#6F603D" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#17140F" Offset="0" />
                                <GradientStop Color="#0B0B0D" Offset="0.55" />
                                <GradientStop Color="#050505" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="PRESET" Foreground="#D6B25E" FontSize="10" FontWeight="Black" />
                                    <TextBlock x:Name="CurrentPresetLabel" Text="Preset đang dùng: Universal Warm Balance" Foreground="#F2E6C8" FontSize="15" FontWeight="Black" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    <TextBlock Text="Màu âm áp theo output hiện tại." Foreground="#A99A72" FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,3,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#241C12" BorderBrush="#D6B25E" BorderThickness="1" CornerRadius="15" Padding="10,5" VerticalAlignment="Top" Margin="10,0,0,0">
                                    <TextBlock x:Name="SoundOutputCountLabel" Text="0 output" Foreground="#E9D8A6" FontSize="10" FontWeight="Black" />
                                </Border>
                            </Grid>
                            <ComboBox x:Name="PresetComboBox" Grid.Row="1" Height="42" SelectionChanged="PresetComboBox_SelectionChanged" Margin="0,12,0,0" />
                            <Border Grid.Row="2" CornerRadius="18" Background="#120F0A" BorderBrush="#D6B25E" BorderThickness="1" Padding="12,9" Margin="0,12,0,10">
