                                <Grid Width="62" Height="62">
                                    <Ellipse Stroke="#3B3020" StrokeThickness="7" />
                                    <Path x:Name="TrebleRadialArc" Stroke="#D6B25E" StrokeThickness="7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 31 6 A 25 25 0 1 1 30.9 6" Opacity="0.9" />
