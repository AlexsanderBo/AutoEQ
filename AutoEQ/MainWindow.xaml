                                    </Polyline.Effect>
                                </Polyline>
                                <TextBlock Text="60" Foreground="#A99A72" FontSize="8" FontWeight="Black" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
                                <TextBlock Text="1K" Grid.Column="1" Foreground="#A99A72" FontSize="8" FontWeight="Black" VerticalAlignment="Bottom" HorizontalAlignment="Center" />
                                <TextBlock Text="4K" Grid.Column="2" Foreground="#A99A72" FontSize="8" FontWeight="Black" VerticalAlignment="Bottom" HorizontalAlignment="Center" />
                                <TextBlock Text="16K" Grid.Column="3" Foreground="#A99A72" FontSize="8" FontWeight="Black" VerticalAlignment="Bottom" HorizontalAlignment="Right" />
                            </Grid>
                        </Grid>
                    </Border>

                     <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="18" BorderBrush="#3B3020" BorderThickness="1" Padding="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#17140F" Offset="0" />
                                    <GradientStop Color="#050505" Offset="1" />
