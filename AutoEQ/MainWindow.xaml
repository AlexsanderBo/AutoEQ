                        </Border>
                        <Border Background="#241C12" CornerRadius="14" Padding="9,5" Margin="0,0,6,6">
                            <TextBlock x:Name="AnalysisStateLabel" Text="Trạng thái: cân bằng" Foreground="#E9D8A6" FontSize="11" FontWeight="Bold" />
                        </Border>
                    </WrapPanel>

                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border x:Name="ManualActionPanel" CornerRadius="24" Padding="12" Margin="0,0,0,12" Background="#17140F" BorderBrush="#3B3020" BorderThickness="1">
                <WrapPanel>
                    <Button x:Name="ApplyButton" Content="Áp dụng preset hiện tại" Width="190" Height="42" Margin="0,0,10,0" Background="#D6B25E" Foreground="#17140F" Click="ApplyButton_Click" />
                    <Button x:Name="OpenConfigButton" Content="Mở cấu hình APO" Width="166" Height="42" Background="#8C5A22" Foreground="#F2E6C8" Click="OpenConfigButton_Click" />
                </WrapPanel>
            </Border>

            <Border Grid.Row="1" CornerRadius="22" Background="#050505" Padding="14" BorderBrush="#272016" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="SYSTEM LOG" Foreground="#D6B25E" FontWeight="Black" FontSize="15" />
                        <TextBlock Text="Thiết bị, preset, Auto EQ, output, lỗi." Foreground="#A99A72" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>
                    <ListBox x:Name="LogListBox" MinHeight="120" Background="#050505" Foreground="#F2E6C8" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="14" Background="#17140F" BorderBrush="#3B3020" BorderThickness="1" Padding="10,8" Margin="0,0,0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Icon}" Foreground="#D6B25E" FontSize="13" FontWeight="Black" VerticalAlignment="Top" Margin="0,1,8,0" />
