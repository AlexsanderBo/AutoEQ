                        </Border>
                        <Border Grid.Column="2" CornerRadius="18" BorderBrush="#3B3020" BorderThickness="1" Padding="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
